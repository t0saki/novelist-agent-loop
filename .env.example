# 复制为 .env 并按需修改。docker-compose 会自动读取。

# 首次启动的管理员密码（留空则随机生成并打印到容器日志）
NOVELIST_ADMIN_PASSWORD=

# 会话签名密钥（留空则在 /data 下持久化随机密钥）
NOVELIST_SESSION_SECRET=

# Postgres 密码（compose 内的 postgres 服务与 novelist 共用）
NOVELIST_PG_PASSWORD=novelist

# WebUI 映射到主机的端口
NOVELIST_PORT=8000

# Mock LLM：true = 不调用真实模型，用脚本化假 LLM 零成本跑通全流程
NOVELIST_MOCK_LLM=false

# 是否随应用启动常驻调度器
NOVELIST_SCHEDULER_ENABLED=true
